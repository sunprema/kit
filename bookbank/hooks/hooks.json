{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-book-hook.sh",
            "timeout": 20,
            "statusMessage": "Validating book structure…"
          }
        ]
      }
    ]
  }
}
